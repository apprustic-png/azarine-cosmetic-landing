rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Koleksi produk: bisa dibaca siapa saja, hanya bisa ditulis oleh admin (semua pengguna ter-auth sementara)
    match /products/{productId} {
      allow read: if true;
      allow write: if true;
    }

    // Koleksi leads: bisa ditulis dari form landing page, hanya bisa dibaca admin
    match /leads/{leadId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
